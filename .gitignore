# ============================================================
# .gitignore — versiona SÓ código. Dados/saídas ficam de fora.
# (Os dados são grandes e mudam toda hora; não fazem parte do código.)
# ============================================================

# --- Bancos de dados e backups ---
*.db
*.db.bak_*
*.sqlite
*.sqlite3
# EXCEÇÃO: cópias versionadas p/ o deploy na nuvem (Streamlit Cloud).
!site/dados_nuvem/
!site/dados_nuvem/financeiro.db
!site/dados_nuvem/bolao.db
# fundos_cvm.db aqui é a versão REDUZIDA (~70MB, top500 + meses intercalados),
# gerada por site/gerar_fundos_nuvem.py — não o banco completo de 214MB.
!site/dados_nuvem/fundos_cvm.db

# --- Dados brutos baixados / processados ---
*.csv
*.json
*.xml
*.zip
cvm_cda/
**/cvm_cda/

# --- Saídas geradas (relatórios, planilhas, PDFs, imagens) ---
*.xlsx
*.xls
*.pdf
*.png
*.jpg
*.jpeg
outputs/
**/outputs/
muffato_dem/

# --- Python ---
__pycache__/
*.pyc
*.pyo
.venv/
venv/
env/
.ipynb_checkpoints/

# --- Streamlit (cópias de dados do site) ---
site/data/
site/carteiras_salvas/
site/log_atualizacao.txt

# --- Sistema / editor ---
.DS_Store
Thumbs.db
.vscode/
*.tmp

# --- HTML de debug solto ---
muffato_debug.html
*.html

# --- Caches grandes (SEC, etc.) ---
**/cache_sec/
**/_cache_*
gestoras_sec/cache_sec/
*.txt
!requirements.txt
!**/requirements.txt

# --- Notebooks e locks de ambiente (dados/efêmeros) ---
*.ipynb
*.lock

# --- Pasta com repositorio Git proprio (mantida separada) ---
teste-github/
